{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "next": true,
  "exclude": ["unresolved"],
  "paths": {
    "@/*": ["./*"]
  },
  "ignoreDependencies": [
    "@hookform/resolvers",
    "@radix-ui/*",
    "autoprefixer",
    "cmdk",
    "date-fns",
    "embla-carousel-react",
